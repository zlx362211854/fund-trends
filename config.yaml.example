# ============================================================
# 基金趋势监控 - 配置文件
# 复制为 config.yaml 并填入你的配置
# ============================================================

# 监控的基金列表(建议 5 只以内)
funds:
  - code: "005827"
    name: "易方达蓝筹精选"
    type: domestic_active        # 国内主动基金

  - code: "040046"
    name: "华夏纳指ETF联接"
    type: qdii_index             # 纳指 QDII(场外)

  - code: "161725"
    name: "招商中证白酒"
    type: domestic_index         # 国内指数基金

# 基金类型说明:
#   domestic_active  - 国内主动基金(当前仅提供时机分)
#   domestic_index   - 国内指数基金(无真实估值时长期分暂不可评估)
#   qdii_index       - 纳斯达克100 QDII(人民币口径基准 + 前瞻PE)

# 双周期评分；每组权重必须各自合计为 1.0
scoring:
  version: observation-v2
  long_term_weights:
    valuation: 0.40               # 真实指数估值
    trend: 0.30                   # 长期趋势
    risk: 0.20                    # 波动与回撤
    tracking: 0.10                # 基金跟踪质量
  timing_weights:
    trend: 0.30                   # MA200趋势状态
    deviation: 0.30               # 波动率标准化偏离
    stabilization: 0.25           # 回撤后的企稳确认
    temperature: 0.15             # RSI与短期变化
  max_valuation_age_days: 7
  min_valuation_samples: 60

# 数据质量阈值(自然日,已覆盖周末和普通节假日)
quality:
  max_nav_age_days: 7
  max_market_age_days: 7
  max_holdings_age_days: 180
  max_news_refresh_age_days: 3
  min_nav_rows: 60

# LLM / 推送的 KEY 走 .env(DEEPSEEK_API_KEY / SERVERCHAN_KEY),
# 此处可只配置非敏感的参数(可选,有默认值)。
llm:
  provider: deepseek
  base_url: "https://api.deepseek.com/v1"
  model: "deepseek-chat"
# push 段不再需要,SendKey 从 .env 读

# 调度时间(本地时区 Asia/Shanghai)
schedule:
  daily_time: "08:00"            # 工作日日报
  weekly_time: "17:00"           # 周五周报
  weekly_day: "friday"

# 数据库
database:
  path: "data/fund_trends.db"

# 日志
logging:
  level: INFO
  path: "logs/fund_trends.log"
